        {
          "name": "3.1 Get Recommendations",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response contains recommendations array\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "    if (jsonData.length > 0) {",
                  "        pm.expect(jsonData[0].rank).to.eql(1);",
                  "        pm.collectionVariables.set(\"recommendedDate\", jsonData[0].date);",
                  "        pm.collectionVariables.set(\"recommendedStart\", jsonData[0].startTime);",
                  "        pm.collectionVariables.set(\"recommendedEnd\", jsonData[0].endTime);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sessions/{{sessionId}}/recommendations?mandatoryIds={{memberId1}},{{memberId2}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "sessions",
                "{{sessionId}}",
                "recommendations"
              ],
              "query": [
                {
                  "key": "mandatoryIds",
                  "value": "{{memberId1}},{{memberId2}}"
                }
              ]
            }
          }
        },
