  "item": [
    {
      "name": "1. Happy Path Scenarios",
      "item": [
        {
          "name": "1.1 Create Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Response contains sessionId and adminToken\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.sessionId).to.be.a('string');",
                  "    pm.expect(jsonData.adminToken).to.be.a('string');",
                  "    pm.collectionVariables.set(\"sessionId\", jsonData.sessionId);",
                  "    pm.collectionVariables.set(\"adminToken\", jsonData.adminToken);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Integration Test Session\",\n  \"domainType\": \"MEETING\",\n  \"members\": [\n    {\n      \"name\": \"Member Alpha\",\n      \"role\": \"Leader\",\n      \"isMandatory\": true\n    },\n    {\n      \"name\": \"Member Beta\",\n      \"role\": \"Developer\",\n      \"isMandatory\": true\n    },\n    {\n      \"name\": \"Member Gamma\",\n      \"role\": \"Designer\",\n      \"isMandatory\": false\n    }\n  ],\n  \"startDate\": \"2026-06-10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/sessions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "sessions"
              ]
            }
          }
        },
        {
          "name": "1.2 Verify Admin (Success)",
          "event": [
